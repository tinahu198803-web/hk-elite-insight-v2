{
  "name": "hk-ipo-tech",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "github": {
    "enabled": true,
    "autoJobCancelation": true
  },
  "crons": [
    {
      "path": "/api/crawl/stock-connect?key=YOUR_CRON_SECRET_KEY",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/crawl/stock-data",
      "schedule": "0 8 * * *"
    }
  ]
}
