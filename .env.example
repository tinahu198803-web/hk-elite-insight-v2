# Azure OpenAI 配置
# 请在 Vercel 项目设置中添加以下环境变量

AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Supabase 配置 (用于存储港股通、指数成分股数据)
# 从 Supabase 项目设置中获取
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# 定时任务密钥 (用于保护cron API)
CRON_SECRET_KEY=your-random-secret-key

# iTick API 配置 (可选 - 如未配置将使用Yahoo Finance备用方案)
# 申请地址: https://itick.org
ITICK_API_KEY=your_itick_api_key

# Finnhub API (可选)
FINNHUB_API_KEY=your_finnhub_api_key

# 示例值：
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2024-12-01-preview
# AZURE_OPENAI_API_KEY=your-api-key-here
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# CRON_SECRET_KEY=a8f5f167f44f4964e6c998dee827110c
